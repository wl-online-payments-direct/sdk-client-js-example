{
  "name": "angular-example",
  "description": "Online Payments JavaScript SDK Angular example app",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "set-env": "node scripts/set-env.js",
    "start": "yarn set-env && concurrently \"ng serve --open\" \"yarn watch-styles\"",
    "build": "yarn set-env && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "copy-design": "node ./../../scripts/copy-design.js src/assets/design/images",
    "copy-styles": "npx sass ../../shared/design/styles/index.scss:./src/assets/design/styles/index.css",
    "watch-styles": "yarn copy-styles --watch",
    "postinstall": "yarn copy-design & yarn copy-styles"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "dependencies": {
    "@angular/common": "21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@types/jasmine": "~5.1.15",
    "@types/node": "^22.13.3",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "typescript": "~5.9.3"
  }
}
