{
    "name": "react-example",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "start": "concurrently \"vite\" \"yarn watch-styles\"",
        "build": "tsc --noEmit --skipLibCheck && vite build",
        "lint": "eslint",
        "preview": "vite preview",
        "copy-design": "node ./../../scripts/copy-design.js ./design/images",
        "copy-styles": "npx sass ../../shared/design/styles/index.scss:./design/styles/index.css",
        "watch-styles": "yarn copy-styles --watch",
        "postinstall": "yarn copy-design & yarn copy-styles"
    },
    "dependencies": {
        "@google-pay/button-react": "^3.2.1",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-router-dom": "^7.7.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.11.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-router-dom": "^5.3.3",
        "@vitejs/plugin-react": "^5.1.4",
        "concurrently": "^9.2.1",
        "eslint": "^10.0.2",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "sass": "^1.97.3",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^7.3.1"
    }
}
