{
    "name": "vue-example",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "start": "concurrently \"vite\" \"yarn watch-styles\"",
        "build": "tsc -b && vite build",
        "lint": "eslint",
        "preview": "vite preview",
        "copy-design": "node ./../../scripts/copy-design.js ./design/images",
        "copy-styles": "npx sass ../../shared/design/styles/index.scss:./design/styles/index.css",
        "watch-styles": "yarn copy-styles --watch",
        "postinstall": "yarn copy-design & yarn copy-styles"
    },
    "dependencies": {
        "vue": "^3.5.29",
        "vue-router": "4"
    },
    "devDependencies": {
        "@types/node": "^24.6.2",
        "@vitejs/plugin-vue": "^6.0.4",
        "@vue/tsconfig": "^0.8.1",
        "concurrently": "^9.2.1",
        "typescript": "~5.9.3",
        "sass": "^1.97.3",
        "vite": "7.3.1",
        "vue-tsc": "^3.2.5"
    }
}
